{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react/recommended",
    "plugin:react/jsx-runtime"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": "./tsconfig.json"
  },
  "plugins": ["@typescript-eslint", "react", "react-hooks", "unicorn"],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/explicit-function-return-type": [
      "error",
      {
        "allowExpressions": true,
        "allowTypedFunctionExpressions": true,
        "allowHigherOrderFunctions": true,
        "allowDirectConstAssertionInArrowFunctions": true
      }
    ],
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "no-var": "error",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["../*"],
            "message": "Use '@/' alias instead of relative '../' imports."
          }
        ]
      }
    ],
    "react/forbid-dom-props": ["error", { "forbid": ["style"] }],
    "unicorn/filename-case": "off"
  },
  "overrides": [
    {
      "files": ["src/gen/**/*"],
      "rules": {
        "unicorn/filename-case": "off"
      }
    },
    {
      "files": ["src/presentation/hooks/**/*.ts", "src/presentation/hooks/**/*.tsx"],
      "rules": {
        "unicorn/filename-case": "off"
      }
    },
    {
      "files": ["src/presentation/components/**/*.tsx"],
      "rules": {
        "unicorn/filename-case": ["error", { "case": "pascalCase" }]
      }
    },
    {
      "files": ["src/presentation/App.tsx", "src/presentation/App.test.tsx"],
      "rules": {
        "unicorn/filename-case": ["error", { "case": "pascalCase" }]
      }
    },
    {
      "files": ["src/**/*.tsx"],
      "excludedFiles": [
        "src/gen/**",
        "src/presentation/hooks/**",
        "src/presentation/components/**",
        "src/presentation/App.tsx",
        "src/presentation/App.test.tsx",
        "**/main.tsx"
      ],
      "rules": {
        "unicorn/filename-case": ["error", { "case": "kebabCase" }]
      }
    },
    {
      "files": ["src/**/*.ts"],
      "excludedFiles": ["src/gen/**", "src/presentation/hooks/**/*.ts"],
      "rules": {
        "unicorn/filename-case": [
          "error",
          {
            "case": "kebabCase",
            "ignore": ["^vite-env\\.d\\.ts$"]
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    "node_modules",
    "static",
    "tests",
    "*.config.ts",
    "proto"
  ]
}
