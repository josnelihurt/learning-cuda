{
  "name": "cuda-image-processor-web",
  "version": "3.0.0",
  "description": "Frontend for CUDA Image Processor with React",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run version:sync && vite build",
    "build:prod": "npm run build",
    "version:sync": "node ./sync-version.mjs",
    "preview": "vite preview",
    "clean": "rm -rf static/js/dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:dev": "TEST_ENV=development playwright test",
    "test:e2e:prod": "TEST_ENV=production playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:dev:ui": "TEST_ENV=development playwright test --ui",
    "test:e2e:prod:ui": "TEST_ENV=production playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:dev:debug": "TEST_ENV=development playwright test --debug",
    "test:e2e:prod:debug": "TEST_ENV=production playwright test --debug",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^1.10.1",
    "@bufbuild/protoc-gen-es": "^1.10.1",
    "@connectrpc/connect": "^1.7.0",
    "@connectrpc/connect-web": "^1.7.0",
    "@connectrpc/protoc-gen-connect-es": "^1.7.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webrtc": "^0.0.46",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^12.10.3",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@openfeature/go-feature-flag-web-provider": "^0.2.9",
    "@openfeature/web-sdk": "^1.7.3",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "^0.206.0",
    "@opentelemetry/core": "1.28.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.206.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.55.0",
    "@opentelemetry/resources": "1.28.0",
    "@opentelemetry/sdk-logs": "^0.206.0",
    "@opentelemetry/sdk-trace-base": "1.28.0",
    "@opentelemetry/sdk-trace-web": "1.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^13.0.0"
  }
}
